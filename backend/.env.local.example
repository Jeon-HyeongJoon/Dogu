CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# Password for the HTTP Basic-protected /admin surface. Empty = admin disabled.
ADMIN_API_KEY=
# Writable dir for mutable state (orders, admin seed edits). Defaults to the
# system temp dir; set to a persistent path/volume for durability.
DOGU_STATE_DIR=
